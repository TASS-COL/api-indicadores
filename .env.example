# ─── Base de datos PostgreSQL ────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=cambia_este_password
PGDATABASE=indicators

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3008
TZ=America/Bogota

# ─── Autenticación JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
JWT_EXPIRES_IN=1h

# API Key maestra para acceso directo
API_KEY=cambia_esta_api_key

# ─── Panel de colas BullMQ ───────────────────────────────────────────────────
DASHBOARD_PATH=/admin/queues
DASHUSER=admin
DASHPASS=cambia_este_password

# ─── Cola de indicadores ─────────────────────────────────────────────────────
INDICATOR_QUEUE_NAME=indicators:tasks
INDICATOR_CRON=0 * * * *

